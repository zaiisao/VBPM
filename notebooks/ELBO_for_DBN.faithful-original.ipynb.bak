    "loss, info = run_algorithm_1(model, h, b, temperature=0.3)\n",
    "\n",
    "fig, ax = plt.subplots(3, 1, figsize=(11, 8))\n",
    "ax[0].plot(history[\"loss\"], label=\"L = -ELBO\")\n",
    "ax[0].plot(history[\"recon\"], label=\"reconstruction\")\n",
    "ax[0].plot(history[\"kl\"], label=\"KL\")\n",
